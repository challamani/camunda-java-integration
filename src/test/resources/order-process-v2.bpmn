    <bpmn:sequenceFlow id="Flow_0iyj71e" sourceRef="Activity_0gf6y5x" targetRef="Event_1jog9qi" />
    <bpmn:sequenceFlow id="Flow_1aswyhx" name="Failed" sourceRef="Gateway_04bjqao" targetRef="Activity_1nid25r">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=IS_QUALITY_PASSED = false</bpmn:conditionExpression>
