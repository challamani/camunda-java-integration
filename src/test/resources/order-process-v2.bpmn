    <bpmn:sequenceFlow id="Flow_0h1s7qv" name="Is Quality Check - Passed" sourceRef="Gateway_04bjqao" targetRef="Activity_0gf6y5x">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=IS_QUALITY_PASSED</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
